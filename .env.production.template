# NextShyft Production Environment Variables Template
# Copy this file and fill in your actual values
# DO NOT commit the filled version to git

# =============================================================================
# CORE APPLICATION
# =============================================================================

# NextAuth Configuration
NEXTAUTH_URL=https://app.YOUR_DOMAIN.com
NEXTAUTH_SECRET=                    # Run: openssl rand -base64 32

# =============================================================================
# DATABASE
# =============================================================================

# MongoDB Atlas (Production Cluster)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/nextshyft?retryWrites=true&w=majority

# =============================================================================
# EMAIL (Resend)
# =============================================================================

RESEND_API_KEY=re_                  # Get from resend.com/api-keys
EMAIL_FROM=no-reply@YOUR_DOMAIN.com # Must match verified domain

# =============================================================================
# BILLING (Stripe - LIVE MODE)
# =============================================================================

STRIPE_SECRET_KEY=sk_live_          # Stripe Dashboard → API Keys (LIVE mode)
STRIPE_WEBHOOK_SECRET=whsec_        # Stripe Dashboard → Webhooks
STRIPE_PRICE_PRO=price_             # Create in Products → Prices
STRIPE_PRICE_BUSINESS=price_        # Create in Products → Prices

# =============================================================================
# PUSH NOTIFICATIONS (VAPID)
# =============================================================================

# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=       # Same as VAPID_PUBLIC_KEY
VAPID_CONTACT_EMAIL=mailto:support@YOUR_DOMAIN.com

# =============================================================================
# OPTIONAL
# =============================================================================

APP_NAME=NextShyft
SUPPORT_EMAIL=support@YOUR_DOMAIN.com

# =============================================================================
# SMS (Twilio - Optional)
# =============================================================================

# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# =============================================================================
# RATE LIMITING (Upstash Redis - Optional)
# =============================================================================

# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
